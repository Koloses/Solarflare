[Desktop Entry]
Actions=RunInTerminal;
Categories=RemoteAccess;Network;
Comment=Self-hosted game stream host for Aurora and Moonlight
Exec=/usr/bin/env systemctl start --u app-@PROJECT_FQDN@
Icon=@SUNSHINE_DESKTOP_ICON@
StartupWMClass=@PROJECT_FQDN@
Keywords=gamestream;stream;aurora;moonlight;remote play;solarflare;
Name=Solarflare
Type=Application
Version=1.0

[Desktop Action RunInTerminal]
Exec=gio launch @CMAKE_INSTALL_FULL_DATAROOTDIR@/applications/@PROJECT_FQDN@.terminal.desktop
Icon=application-x-executable
Name=Run in Terminal
